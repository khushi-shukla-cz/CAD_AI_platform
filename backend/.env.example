# CORS Configuration
# Comma-separated list of allowed origins (wildcards rejected for security)
CAD_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Comma-separated list of allowed HTTP methods
CAD_CORS_ALLOWED_METHODS=GET,POST,OPTIONS

# Comma-separated list of allowed headers
CAD_CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,Origin,X-Requested-With

# Upload Configuration
# Maximum upload size in bytes (default: 26MB)
CAD_MAX_UPLOAD_BYTES=26214400

# Streaming read chunk size in bytes (default: 1MB)
CAD_UPLOAD_CHUNK_SIZE=1048576

# Rate Limiting Configuration
# Maximum requests per window (default: 12)
CAD_RATE_LIMIT_REQUESTS_PER_WINDOW=12

# Rate limit window duration in seconds (default: 60)
CAD_RATE_LIMIT_WINDOW_SECONDS=60
